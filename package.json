{
  "name": "devrooms",
  "version": "0.0.1",
  "private": false,
  "description": "Project-aware dev rooms for Hermes and coding agents.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n daemon,ui -c blue,magenta \"pnpm dev:daemon\" \"pnpm dev:ui\"",
    "dev:daemon": "tsx watch src/server.ts",
    "dev:ui": "vite --host 127.0.0.1",
    "build": "tsc -p tsconfig.server.json && vite build",
    "start": "node dist/server.js",
    "check": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "test": "pnpm run check && pnpm run build && pnpm run smoke",
    "lint": "pnpm check"
  },
  "keywords": ["agents", "developer-tools", "hermes", "terminal", "git"],
  "author": "sbbu",
  "license": "MIT",
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
