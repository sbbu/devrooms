{
  "name": "devrooms",
  "version": "0.0.1",
  "private": false,
  "description": "Project-aware dev rooms for Hermes and coding agents.",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "concurrently -n daemon,ui -c blue,magenta \"pnpm dev:daemon\" \"pnpm dev:ui\"",
    "dev:daemon": "node scripts/dev-daemon.mjs",
    "dev:ui": "vite --host 127.0.0.1",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "stop": "node scripts/stop.mjs",
    "build": "tsc -p tsconfig.server.json && tsc -p tsconfig.electron.json && vite build",
    "desktop": "pnpm build && electron dist/electron/main.js",
    "install:mac": "bash scripts/install-mac.sh",
    "package:mac": "pnpm build && pnpm run rebuild:native && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir --config electron-builder.yml",
    "smoke:install": "node scripts/install-smoke.mjs",
    "smoke:package": "node scripts/package-smoke.mjs",
    "start": "node dist/server.js",
    "check": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.electron.json --noEmit && tsc -p tsconfig.client.json --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "design:review": "bash scripts/claude-design-review.sh",
    "test": "pnpm run check && pnpm run build && pnpm run smoke",
    "lint": "pnpm check",
    "rebuild:native": "node scripts/rebuild-native.mjs"
  },
  "keywords": [
    "agents",
    "developer-tools",
    "hermes",
    "terminal",
    "git"
  ],
  "author": "sbbu",
  "license": "MIT",
  "dependencies": {
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "express": "^5.2.1",
    "highlight.js": "^11.11.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.2",
    "concurrently": "^9.2.1",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@homebridge/node-pty-prebuilt-multiarch",
      "electron",
      "esbuild"
    ]
  }
}
